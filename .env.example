# Proveedor activo del análisis LLM: "gemini" u "openrouter".
# Cambiar de uno a otro es SOLO esta variable; el resto del sistema no se toca.
LLM_PROVIDER=gemini

# --- Gemini (https://aistudio.google.com/app/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Orígenes permitidos por CORS para el backend (separados por coma)
CORS_ALLOW_ORIGINS=http://localhost:5173

# URL del WebSocket que usa el frontend para hablar con el backend
VITE_WS_URL=ws://localhost:8000/ws/session
